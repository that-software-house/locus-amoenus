---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Thanks for Joining | Locus Amoenus"
  description="Your waitlist request has been received."
  canonicalPath="/thanks/"
  noindex={true}
>
  <main class="blog-main">
    <section class="section blog-hero" style="margin-top: 3rem; text-align: center;">
      <p class="eyebrow">Waitlist</p>
      <h1>Thanks, you're on the list.</h1>
      <p class="lead">We will send launch updates and early access details to your inbox.</p>
      <p style="margin-top: 1rem;">
        <a class="btn btn-primary" href="/">Return Home</a>
      </p>
    </section>
  </main>
</BaseLayout>
