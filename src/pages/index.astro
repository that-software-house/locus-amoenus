---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Locus Amoenus',
  url: 'https://locusamoenus.com/',
  logo: 'https://locusamoenus.com/og-cover.png',
  description:
    'Locus Amoenus builds immersive virtual reality memory spaces for reflection and storytelling.'
};

const siteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Locus Amoenus',
  url: 'https://locusamoenus.com/'
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'When will early access open?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Locus Amoenus is onboarding users in waves. Waitlist members receive updates first.'
      }
    },
    {
      '@type': 'Question',
      name: 'How are waitlist emails stored?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Waitlist submissions are captured through Netlify Forms and can be exported to CSV.'
      }
    },
    {
      '@type': 'Question',
      name: 'Can I submit without VR hardware?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. You can join from desktop or mobile and receive updates before hardware rollout phases.'
      }
    }
  ]
};
---

<BaseLayout
  title="Locus Amoenus | VR Memory Experiences & Early Access Waitlist"
  description="Locus Amoenus is building immersive VR memory spaces for reflection, remembrance, and storytelling. Join the waitlist and read the latest research on our blog."
  canonicalPath="/"
>
  <a class="skip-link" href="#content">Skip to content</a>
  <video class="bg-video" autoplay muted loop playsinline poster="/og-cover.png" aria-hidden="true">
    <source src="/bg_video.mp4" type="video/mp4" />
  </video>
  <div class="bg-overlay" aria-hidden="true"></div>
  <div class="bg-grid" aria-hidden="true"></div>

  <header class="site-header">
    <a class="brand" href="#top">
      <span class="brand-mark"></span>
      <span>Locus Amoenus</span>
    </a>
    <nav aria-label="Primary">
      <ul class="nav-list">
        <li><a data-nav-link href="#experience">Experience</a></li>
        <li><a data-nav-link href="#method">Method</a></li>
        <li><a data-nav-link href="#insights">Insights</a></li>
        <li><a data-nav-link href="#waitlist">Waitlist</a></li>
        <li><a href="/blog/">Blog</a></li>
      </ul>
    </nav>
  </header>

  <main id="content">
    <section id="top" class="hero">
      <p class="eyebrow reveal">Immersive Memory Spaces</p>
      <h1 class="reveal">A calm digital place to revisit stories, voices, and moments that matter.</h1>
      <p class="lead reveal">
        Locus Amoenus turns memory into guided, cinematic VR environments designed for reflection and meaningful
        connection.
      </p>
      <div class="cta-row reveal">
        <a class="btn btn-primary" href="#waitlist">Join The Waitlist</a>
        <a class="btn btn-ghost" href="/blog/">Read Research Blog</a>
      </div>
    </section>

    <section id="experience" class="section reveal">
      <h2>Why Locus Amoenus</h2>
      <p>
        Most memory tools are static timelines. We are building an experiential layer where memory becomes spatial: a
        place you can enter, explore, and revisit with intention.
      </p>
      <div class="card-grid">
        <article class="card">
          <h3>Memory Journeys</h3>
          <p>Move through story-led environments built from photos, audio, and narrative prompts.</p>
        </article>
        <article class="card">
          <h3>Guided Reflection</h3>
          <p>Scenes are paced for emotional clarity, not sensory overload.</p>
        </article>
        <article class="card">
          <h3>Shared Presence</h3>
          <p>Invite close family or trusted collaborators into selected moments.</p>
        </article>
      </div>
    </section>

    <section id="method" class="section reveal">
      <h2>How It Works</h2>
      <ol class="timeline">
        <li>
          <span>01</span>
          <p>Collect core memory artifacts: photos, voice notes, letters, and locations.</p>
        </li>
        <li>
          <span>02</span>
          <p>Generate a narrative architecture that maps emotional beats into spatial scenes.</p>
        </li>
        <li>
          <span>03</span>
          <p>Deliver a curated VR journey, then iterate with user feedback and reflection data.</p>
        </li>
      </ol>
    </section>

    <section id="insights" class="section reveal">
      <div class="section-head">
        <h2>Latest Insights</h2>
        <a class="text-link" href="/blog/">View all articles</a>
      </div>
      <div class="card-grid">
        {
          posts.map((post) => (
            <article class="card">
              <p class="card-meta">
                {post.data.pubDate.toLocaleDateString('en-US', {
                  month: 'long',
                  day: '2-digit',
                  year: 'numeric'
                })}
              </p>
              <h3>
                <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
              </h3>
              <p>{post.data.description}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section id="faq" class="section reveal">
      <h2>FAQ</h2>
      <div class="faq">
        <details>
          <summary>When will early access open?</summary>
          <p>We are currently onboarding in waves. Waitlist members receive release updates first.</p>
        </details>
        <details>
          <summary>How are waitlist emails stored?</summary>
          <p>Submissions are captured through Netlify Forms, exportable to CSV or CRM sync.</p>
        </details>
        <details>
          <summary>Can I submit without VR hardware?</summary>
          <p>Yes. You can join from desktop or mobile and receive updates before hardware rollout phases.</p>
        </details>
      </div>
    </section>

    <section id="waitlist" class="section section-cta reveal">
      <h2>Join The Waitlist</h2>
      <p>Get launch updates, pilot invitations, and new research articles.</p>
      <form
        class="waitlist-form"
        name="waitlist"
        method="POST"
        action="/thanks/"
        data-netlify="true"
        netlify-honeypot="bot-field"
        data-waitlist-form
      >
        <input type="hidden" name="form-name" value="waitlist" />
        <input type="hidden" name="source" value="homepage" />
        <input type="hidden" name="utm_source" />
        <input type="hidden" name="utm_medium" />
        <input type="hidden" name="utm_campaign" />
        <input type="hidden" name="utm_term" />
        <input type="hidden" name="utm_content" />
        <input type="hidden" name="referrer" />
        <p class="hidden-field">
          <label>Leave this field empty: <input name="bot-field" /></label>
        </p>
        <label for="email">Email address</label>
        <div class="input-row">
          <input id="email" name="email" type="email" placeholder="you@domain.com" required />
          <button type="submit">Request Early Access</button>
        </div>
        <label class="consent">
          <input type="checkbox" name="consent" required />
          <span>I agree to receive product updates and research notes.</span>
        </label>
        <p class="form-note">No spam. Unsubscribe anytime.</p>
        <p class="form-status" data-form-status aria-live="polite"></p>
      </form>
    </section>
  </main>

  <footer class="site-footer">
    <p>&copy; <span data-year></span> Locus Amoenus</p>
    <div class="footer-links">
      <a href="/blog/">Blog</a>
      <a href="mailto:hello@locusamoenus.com">Contact</a>
    </div>
  </footer>

  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(siteSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
  <script src="/app.js" defer></script>
</BaseLayout>
